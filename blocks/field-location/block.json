{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "aucteeno/field-location",
	"title": "Aucteeno Location",
	"category": "aucteeno",
	"icon": "location",
	"description": "Display the auction or item location.",
	"keywords": [ "aucteeno", "location", "city", "country" ],
	"textdomain": "aucteeno",
	"usesContext": [ "aucteeno/item", "aucteeno/itemType" ],
	"supports": {
		"html": false,
		"align": [ "left", "center", "right", "wide", "full" ],
		"color": {
			"gradients": true,
			"link": true,
			"__experimentalDefaultControls": {
				"background": true,
				"text": true,
				"link": true
			}
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": false,
				"padding": false
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": false,
				"radius": false,
				"style": false,
				"width": false
			}
		}
	},
	"attributes": {
		"showLabel": { "type": "boolean", "default": true },
		"label": { "type": "string", "default": "Location" },
		"showIcon": { "type": "boolean", "default": true },
		"format": { "type": "string", "default": "smart" },
		"showLinks": { "type": "boolean", "default": false },
		"orientation": { "type": "string", "default": "column", "enum": [ "row", "column" ] }
	},
	"editorScript": "file:../../dist/blocks/field-location/editor.js",
	"style": "file:../../dist/blocks/field-location/style-editor.css",
	"render": "file:./render.php"
}
