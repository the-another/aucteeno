{
  "name": "aucteeno",
  "version": "1.7.3",
  "description": "Aucteeno WordPress Plugin - Gutenberg Blocks",
  "private": true,
  "scripts": {
    "build": "wp-scripts build --config webpack.config.js",
    "start": "wp-scripts start --config webpack.config.js",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "wp-scripts lint-js blocks/*/src/*.js",
    "lint:css": "wp-scripts lint-style blocks/*/src/*.css",
    "test": "wp-scripts test-unit-js --passWithNoTests",
    "format": "wp-scripts format blocks/*/src/*.js",
    "plugin-zip": "composer update && composer build && npm run build && npm install && wp-scripts plugin-zip > /dev/null 2>&1 && node scripts/version-zip.js",
    "version": "node scripts/version-bump.js && npm install && make update",
    "version:patch": "node scripts/version-bump.js patch && npm install && make update",
    "version:minor": "node scripts/version-bump.js minor && npm install && make update",
    "version:major": "node scripts/version-bump.js major && npm install && make update"
  },
  "devDependencies": {
    "@babel/runtime": "^7.28.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@wordpress/api-fetch": "^7.51.0",
    "@wordpress/block-editor": "^16.0.0",
    "@wordpress/blocks": "^15.24.0",
    "@wordpress/components": "^37.0.0",
    "@wordpress/data": "^10.51.0",
    "@wordpress/element": "^8.3.0",
    "@wordpress/hooks": "^4.51.0",
    "@wordpress/i18n": "^6.24.0",
    "@wordpress/scripts": "^33.0.0"
  },
  "dependencies": {
    "@wordpress/interactivity": "^6.0.0",
    "jquery": "^3.7.1"
  },
  "overrides": {
    "markdown-it": "^14.3.0",
    "linkify-it": "^5.0.2",
    "serialize-javascript": "^7.0.7",
    "webpack-dev-server": "^5.2.5",
    "@opentelemetry/core": "^2.9.0",
    "markdownlint-cli": {
      "minimatch": "^3.1.5"
    },
    "sockjs": {
      "uuid": "^11.1.1"
    }
  },
  "files": [
    "aucteeno.php",
    "composer.json",
    "README.md",
    "readme.txt",
    "assets",
    "blocks/**/block.json",
    "blocks/**/render.php",
    "!blocks/**/index.js",
    "!blocks/**/editor.scss",
    "dist",
    "includes/**",
    "languages",
    "templates/**",
    "vendor/autoload.php",
    "vendor/composer"
  ]
}
